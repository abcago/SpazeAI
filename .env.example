# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=spazeai
POSTGRES_PASSWORD=change-me
POSTGRES_DB=spazeai

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-this-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-min-32

# ── Cloudflare R2 (S3-compatible) ────────────────────────
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=spazeai
R2_PUBLIC_URL=https://your-r2-public-domain.com

# ── FAL.ai (Image Generation) ───────────────────────────
FAL_API_KEY=your-fal-api-key

# ── Backoffice Auth (NextAuth / Google OAuth) ────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAILS=admin@example.com

# ── App URLs (defaults work for local dev) ───────────────
# NEXTAUTH_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3001
# CORS_ORIGINS=http://localhost:3000,http://localhost:3002
# NODE_ENV=development
