DATABASE_URL=postgresql://user:password@localhost:5432/spazeai
JWT_SECRET=your-super-secret-key-change-this-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-min-32
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Cloudflare R2 (S3-compatible)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=spazeai
R2_PUBLIC_URL=https://your-r2-public-domain.com

# FAL.ai API key for image generation
FAL_API_KEY=your-fal-api-key
